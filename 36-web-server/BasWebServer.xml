     <EmbeddedData><![CDATA[[{"data":"await (new Promise((resolve, reject) => {\r\n\r\nvar express = require('express');\r\nvar app = express();\r\n\r\n// Функция для проверки Bearer-токена\r\n    function checkAuth(req, res, next) {\r\n        const authHeader = req.headers['authorization'];\r\n\r\n        if (!authHeader || !authHeader.startsWith('Bearer ')) {\r\n            return res.status(401).json({ error: 'Нет токена или неверный формат' });\r\n        }\r\n\r\n        const token = authHeader.split(' ')[1]; // Извлекаем токен\r\n\r\n        if (token !== [[APIKEY]]) { // Здесь можно сделать проверку через JWT\r\n            return res.status(403).json({ error: 'Недействительный токен' });\r\n        }\r\n\r\n        next(); // Передаём управление дальше\r\n    }\r\n\t\r\n// Поддержка JSON и form-data\r\napp.use(express.json()); // позволяет принимать JSON\r\napp.use(express.urlencoded({ extended: true })); // для понимания входящих данных\r\n\r\n// Обработка POST-запросов к /task с проверкой токена\r\napp.post('/task', checkAuth, function (req, res) {\r\n    [[REQ_BODY]] = JSON.stringify(req.body);\r\n    //console.log(req.body);\r\n    BAS_API('RInsert(\"Tasks\",VAR_REQ_BODY,false)');\r\n    res.send('<h1>Запрос принят от сервера!</h1>');\r\n});\r\n\r\n// Запуск сервера на указанном порту\r\nvar server = app.listen([[PORT]], function () {\r\n    console.log('Example app listening http://127.0.0.1:' + [[PORT]]);\r\n});\r\n    \r\n}));","data_name":"ak8f9710kzd","data_type":0,"language_name":"Node","language_version":"22.11.0"}]]]></EmbeddedData>
